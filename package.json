{
  "name": "mikro-orm-markdown",
  "version": "0.1.0",
  "description": "Generate Mermaid ERD and Markdown documentation from MikroORM entities",
  "keywords": [
    "mikro-orm",
    "erd",
    "mermaid",
    "markdown",
    "documentation",
    "entity",
    "database"
  ],
  "author": "iamkanguk97 (https://github.com/iamkanguk97)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iamkanguk97/mikro-orm-markdown.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "mikro-orm-markdown": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --project tsconfig.test.json --noEmit",
    "lint": "eslint src test",
    "lint:fix": "eslint src test --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "peerDependencies": {
    "@mikro-orm/core": ">=6.0.0"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "ts-morph": "^23.0.0"
  },
  "devDependencies": {
    "@mikro-orm/core": "^6.0.0",
    "@mikro-orm/sqlite": "^6.0.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
