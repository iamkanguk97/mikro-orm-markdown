{
  "name": "mikro-orm-markdown",
  "version": "0.1.0",
  "description": "Generate Mermaid ERD and Markdown documentation from MikroORM entities",
  "keywords": [
    "mikro-orm",
    "erd",
    "mermaid",
    "markdown",
    "documentation",
    "entity",
    "database"
  ],
  "author": "iamkanguk97",
  "license": "MIT",
  "packageManager": "npm@10.9.2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iamkanguk97/mikro-orm-markdown.git"
  },
  "bugs": {
    "url": "https://github.com/iamkanguk97/mikro-orm-markdown/issues"
  },
  "homepage": "https://github.com/iamkanguk97/mikro-orm-markdown#readme",
  "engines": {
    "node": ">=18.19.0"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "mikro-orm-markdown": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "README.ko.md",
    "LICENSE",
    "CHANGELOG.md",
    "SECURITY.md",
    "CODE_OF_CONDUCT.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "example:erd": "npm run build && cd examples && node ../dist/cli.js -c mikro-orm.config.ts -o ERD.md -t \"Example Schema\" -d \"Generated from the entities in examples/entities - a tour of every feature mikro-orm-markdown can render.\"",
    "typecheck": "tsc --project tsconfig.test.json --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "vitest run",
    "test:pack": "node scripts/pack-smoke.mjs",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test && npm run build",
    "prepare": "node .husky/install.mjs"
  },
  "peerDependencies": {
    "@mikro-orm/core": ">=6.0.0",
    "@mikro-orm/reflection": ">=6.0.0",
    "tsx": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@mikro-orm/reflection": {
      "optional": true
    },
    "tsx": {
      "optional": true
    }
  },
  "dependencies": {
    "commander": "^12.0.0",
    "ts-morph": "^23.0.0"
  },
  "lint-staged": {
    "*.{ts,js,json,jsonc,yml,yaml,md}": "biome check --write --no-errors-on-unmatched"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@mikro-orm/core": "^7.1.5",
    "@mikro-orm/mariadb": "^7.1.5",
    "@mikro-orm/mysql": "^7.1.5",
    "@mikro-orm/postgresql": "^7.1.5",
    "@mikro-orm/reflection": "^7.1.5",
    "@mikro-orm/sqlite": "^7.1.5",
    "@types/node": "^18.19.130",
    "@vitest/coverage-v8": "^2.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "tsup": "^8.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
